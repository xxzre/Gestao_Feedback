rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Leitura publica de usuarios (permitindo selecionar gestores no cadastro deslogado)
    // Escrita permitida para usuarios autenticados
    match /users/{userId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // Permite leitura e escrita de feedbacks se o usuario estiver autenticado
    match /feedbacks/{feedbackId} {
      allow read, write: if request.auth != null;
    }
    
    // Permite leitura e escrita da agenda se o usuario estiver autenticado
    match /agenda/{agendaId} {
      allow read, write: if request.auth != null;
    }
    
    // Permite leitura e escrita de resultados do DISC
    match /discResults/{userId} {
      allow read, write: if request.auth != null;
    }
  }
}
